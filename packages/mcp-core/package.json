{
  "name": "@discord-mcp/core",
  "version": "0.12.0",
  "private": false,
  "type": "module",
  "description": "Production-grade Discord MCP server core — 192 tools, OTel-instrumented, cockatiel-resilient.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "discord",
    "ai",
    "claude",
    "cursor"
  ],
  "license": "MIT",
  "homepage": "https://cappylab.github.io/discord-mcp/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cappylab/discord-mcp.git",
    "directory": "packages/mcp-core"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "typecheck": "tsc --noEmit",
    "prepack": "node -e \"require('node:fs').copyFileSync('../../README.md','README.md');require('node:fs').copyFileSync('../../LICENSE','LICENSE');\"",
    "postpack": "node -e \"try{require('node:fs').unlinkSync('README.md');require('node:fs').unlinkSync('LICENSE');}catch{}\""
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@discordjs/rest": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.216.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-metrics": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "@sapphire/pieces": "^4.4.1",
    "cockatiel": "^3.2.1",
    "discord-api-types": "^0.38.0",
    "pino": "^9.5.0",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@discord-mcp/server-mocks": "workspace:*",
    "@mswjs/interceptors": "^0.41.3",
    "@opentelemetry/context-async-hooks": "^2.0.0",
    "@types/node": "^22.0.0",
    "msw": "^2.7.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
