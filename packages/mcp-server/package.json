  },
  "dependencies": {
    "@discord-mcp/core": "workspace:*",
    "@discordjs/rest": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.20.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.10",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  }
}
