# Worktrees (subagent-driven development isolation)
.worktrees/

# Build artifacts
node_modules/
dist/
.turbo/
coverage/

# Logs
*.log

# Env
.env
.env.local

# OS
.DS_Store

# Editors
.vscode/
.idea/

# Contens — internal plans/research stay private (docs/superpowers/, etc.).
# Operator docs (docs/operations/, docs/v1.0.0-readiness.md) ship to the public
# repo via the negations below. NB: gitignore "cannot re-include a file if a
# parent directory is excluded", so we ignore docs/* (files inside docs/, not
# docs/ itself).
docs/*
!docs/operations/
!docs/v1.0.0-readiness.md

# Agents
.claude/
.agents/

# Site (Astro Starlight)
site/dist
site/.astro
site/node_modules
site/src/content/docs/tools/
